{
  "name": "ingo-steinke.de",
  "version": "5.0.3",
  "description": "website about web developer Ingo Steinke",
  "main": "index.html",
  "scripts": {
    "eslint": "eslint src",
    "stylelint": "stylelint src/*.css src/_includes/*.css",
    "tsc": "tsc",
    "build": "npm run eslint && npm run stylelint && npm run build:de && npm run build:en",
    "build:de": "eleventy --config .eleventy.de.js && node_modules/.bin/postcss src/*.css --dir dist && npm run build:ts:de",
    "build:en": "eleventy --config .eleventy.en.js && node_modules/.bin/postcss src/*.css --dir dist_en && npm run build:ts:en",
    "build:ts:de": "esbuild src/ts/main.ts --bundle --platform=browser --target=es2020 --format=iife --outfile=dist/js/scripts.js --minify",
    "build:ts:en": "esbuild src/ts/main.ts --bundle --platform=browser --target=es2020 --format=iife --outfile=dist_en/js/scripts.js --minify",
    "dev": "npm run serve",
    "serve": "npx http-server dist -p 1974 --cors &",
    "serve:en": "npx http-server dist_en -p 1974 --cors &",
    "pretest": "npm run build && npm run serve",
    "test": "npm run codeceptjs",
    "posttest": "pkill -f http-server",
    "unserve": "pkill -f http-server"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmindculture/ingo-steinke.de.git"
  },
  "author": "Ingo Steinke",
  "license": "proprietary",
  "bugs": {
    "url": "https://github.com/openmindculture/ingo-steinke.de/issues"
  },
  "homepage": "https://github.com/openmindculture/ingo-steinke.de#readme",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.0",
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.9.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "autoprefixer": "^10.4.20",
    "clean-css": "^5.3.3",
    "cssnano": "^7.0.6",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "globals": "^15.9.0",
    "html-minifier-terser": "^7.2.0",
    "http-server": "^14.1.1",
    "postcss": "^8.4.45",
    "postcss-cli": "^11.0.0",
    "postcss-custom-properties": "^14.0.1",
    "postcss-custom-selectors": "^8.0.1",
    "postcss-import": "^16.1.0",
    "precss": "^4.0.0",
    "puppeteer": "^23.3.0",
    "stylelint": "^16.9.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^36.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
