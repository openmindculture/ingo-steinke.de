<!DOCTYPE html>
<html lang="de">
<head>
  <meta http-equiv="content-type" content="text/html; charset=utf-8">
  <title>Webentwickler Ingo Steinke: über mich</title>
  {% include '../_includes/html-head-common.liquid' %}
</head>
<body class="high-contrast">
<div class="page-container" id="top">
  <div class="page-content">
    <header class="jumbotronHeader" id="jumbotronHeader">
      <br>
      {% include './_includes/jumbotron-image.liquid' %}
      <h1>Ingo Steinke: über mich<br>CV, Projekte, Skills</h1>
      <br>
    </header>
    {% include '../_includes/navigation-on-subpages.liquid' %}
    <main id="content-top" class="target-offset">

      <section class="text-content-layout text-content-color">
        <article class="text-width">
          <h2>Alles auf einen Blick</h2>
          Werdegang/CV, Projektliste und Skillmatrix als PDF herunterladen:
          <ul>
            <li><a href="../Ingo-Steinke-CV-Projekte-Skills-2024-nachhaltiger-Webentwickler.pdf" target="_blank"
                   rel="noopener noreferrer nofollow">Ingo Steinke, Webentwickler, Berlin: CV, Skills, Projekte</a>
              (deutsch, Stand: Februar 2024)
            </li>
            <li><a href="../Ingo-Steinke-CV-Projects-Skills-2024-sustainable-web-developer.pdf" target="_blank"
                   rel="noopener noreferrer nofollow">Ingo Steinke, web developer, Berlin: CV, skills, projects</a>
              (englisch, Stand: Februar 2024)
            </li>
          </ul>
        </article>
      </section>

      <section class="text-content-layout text-content-color semitransparent avoid-page-break">
        <h2 class="target-offset" id="about-me">
          {{ content.aboutMeHeading }}
        </h2>
        <article class="text-width">
          <header>
            <h3>
              {{ content.aboutMeIntroHeading }}
            </h3>
          </header>
          <p class="capitalized"><!-- overcapitalize first letter -->
            {{ content.aboutMeIntro }}
          </p>

          <section class="avoid-page-break">
            <h3>{{ content.aboutMeCvHeading }}</h3>
            <p>
              {{ content.aboutMeCv1 }}
            </p>
            <p>
              {{ content.aboutMeCv2 }}
            </p>
          </section>

          <section class="avoid-page-break">
            <h4>{{ content.aboutMeEthicalHeading }}</h4>
            <p>
              {{ content.aboutMeEthical }}
            </p>
            <p>
              {{ content.careAboutGoingBeyond }}
            </p>
          </section>

        </article>
      </section>

      {% include './_includes/projects.liquid', showallprojects: 'showallprojects', showicons: 'showicons'  %}

      <span id="services"></span>
      {% include './_includes/skills.liquid', showallskills: 'showallskills', skillsTitle: 'Leistungen: Fachkenntnisse (Skills)'  %}

      <section class="tiled-content target-offset"><!-- TODO improve layout -->
        <h3 id="interested">{{ content.interestedHeading }}</h3>
        <p>
          Melde dich gerne, um ein unverbindliches Gespräch zu vereinbaren!
          Falls ich einen Anruf nicht persönlich entgegennehmen kann, hinterlasse mir gerne eine Sprachnachricht!
        </p>
      </section>
      <br>

      {% include '../_includes/section-imprint-contact.liquid' %}
    </main>
    {% include '../_includes/page-footer-on-subpages.liquid' %}
